<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:remename.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="1180"
             d:DesignHeight="760"
             x:Class="remename.Views.MainView"
             x:DataType="vm:MainViewModel">

  <Design.DataContext>
    <vm:MainViewModel />
  </Design.DataContext>

  <UserControl.Resources>
    <SolidColorBrush x:Key="CanvasBrush" Color="#F5F7F8" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="BorderBrush" Color="#DDE3E7" />
    <SolidColorBrush x:Key="TextBrush" Color="#17212B" />
    <SolidColorBrush x:Key="MutedBrush" Color="#66747F" />
    <SolidColorBrush x:Key="AccentBrush" Color="#1769E0" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#0F5AC5" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#EAF2FF" />
    <SolidColorBrush x:Key="SuccessBrush" Color="#16805A" />
    <SolidColorBrush x:Key="SuccessSoftBrush" Color="#E8F7F0" />
  </UserControl.Resources>

  <UserControl.Styles>
    <Style Selector="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    </Style>
    <Style Selector="TextBlock.page-title">
      <Setter Property="FontSize" Value="20" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="TextBlock.section-title">
      <Setter Property="FontSize" Value="14" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="TextBlock.field-label">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
      <Setter Property="Margin" Value="0,0,0,6" />
    </Style>
    <Style Selector="TextBlock.muted">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
    </Style>
    <Style Selector="TextBlock.file-name">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="Medium" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>
    <Style Selector="TextBlock.preview-name">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>
    <Style Selector="TextBox.desktop-input">
      <Setter Property="MinHeight" Value="38" />
      <Setter Property="Padding" Value="11,7" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
      <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
    </Style>
    <Style Selector="Button.command">
      <Setter Property="MinHeight" Value="38" />
      <Setter Property="Padding" Value="14,7" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="Medium" />
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="{StaticResource AccentBrush}" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="Button.primary:pointerover">
      <Setter Property="Background" Value="{StaticResource AccentHoverBrush}" />
    </Style>
    <Style Selector="Button.secondary">
      <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Button.secondary:pointerover">
      <Setter Property="Background" Value="#F0F3F5" />
    </Style>
    <Style Selector="Border.sidebar-section">
      <Setter Property="Padding" Value="20" />
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>
    <Style Selector="TabControl.rename-tabs">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="TabItem">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="Medium" />
      <Setter Property="Padding" Value="12,8" />
    </Style>
    <Style Selector="ListBox.file-list">
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Padding" Value="0" />
    </Style>
    <Style Selector="ListBox.file-list ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="MinHeight" Value="54" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="CornerRadius" Value="0" />
    </Style>
    <Style Selector="ListBox.file-list ListBoxItem /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="ListBox.file-list ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#F6F8F9" />
    </Style>
  </UserControl.Styles>

  <Grid x:Name="LayoutRoot"
        RowDefinitions="68,*,62"
        Background="{StaticResource CanvasBrush}">

    <Border Grid.Row="0"
            Padding="22,0"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
        <Image Width="34" Height="34" Source="/Assets/app-icon.png"
               VerticalAlignment="Center" />
        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
          <TextBlock Classes="page-title" Text="批量重命名" />
          <TextBlock Classes="muted" Text="{Binding SelectedPath}"
                     TextTrimming="CharacterEllipsis"
                     IsVisible="{Binding HasSelectedPath}" />
        </StackPanel>
        <StackPanel Grid.Column="2" Orientation="Horizontal"
                    VerticalAlignment="Center" Spacing="8">
          <Border Padding="10,6" CornerRadius="6" Background="{StaticResource AccentSoftBrush}">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="{Binding FileList.Count}" Foreground="{StaticResource AccentBrush}"
                         FontWeight="SemiBold" FontSize="12" />
              <TextBlock Text="个文件" Foreground="{StaticResource AccentBrush}" FontSize="12" />
            </StackPanel>
          </Border>
          <Border Padding="10,6" CornerRadius="6" Background="{StaticResource SuccessSoftBrush}"
                  IsVisible="{Binding HasSelectedFiles}">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="{Binding SelectedCount}" Foreground="{StaticResource SuccessBrush}"
                         FontWeight="SemiBold" FontSize="12" />
              <TextBlock Text="个已选" Foreground="{StaticResource SuccessBrush}" FontSize="12" />
            </StackPanel>
          </Border>
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="340,*">
      <Border Grid.Column="0"
              Background="{StaticResource SurfaceBrush}"
              BorderBrush="{StaticResource BorderBrush}"
              BorderThickness="0,0,1,0">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
          <StackPanel>
            <Border Classes="sidebar-section">
              <StackPanel Spacing="12">
                <TextBlock Classes="section-title" Text="目标文件夹" />
                <TextBox Classes="desktop-input"
                         Text="{Binding SelectedPath}"
                         PlaceholderText="选择或输入文件夹路径"
                         AcceptsReturn="False" />
                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                  <Button Classes="command primary"
                          Content="浏览文件夹"
                          Command="{Binding SelectFolderCommand}"
                          HorizontalAlignment="Stretch" />
                  <Button Grid.Column="1"
                          Classes="command secondary"
                          Content="刷新"
                          Command="{Binding RefreshCommand}"
                          IsEnabled="{Binding HasSelectedPath}"
                          HorizontalAlignment="Stretch" />
                </Grid>
              </StackPanel>
            </Border>

            <Border Classes="sidebar-section" BorderThickness="0">
              <StackPanel Spacing="12">
                <TextBlock Classes="section-title" Text="重命名规则" />
                <TabControl Classes="rename-tabs"
                            SelectedIndex="{Binding RenameMode}">
                  <TabItem Header="普通替换">
                    <StackPanel Margin="0,14,0,0" Spacing="12">
                      <StackPanel>
                        <TextBlock Classes="field-label" Text="搜索内容" />
                        <TextBox Classes="desktop-input"
                                 Text="{Binding SearchText}"
                                 PlaceholderText="要替换的文字" />
                      </StackPanel>
                      <StackPanel>
                        <TextBlock Classes="field-label" Text="替换为" />
                        <TextBox Classes="desktop-input"
                                 Text="{Binding ReplaceText}"
                                 PlaceholderText="留空表示删除" />
                      </StackPanel>
                    </StackPanel>
                  </TabItem>
                  <TabItem Header="季度剧集">
                    <StackPanel Margin="0,14,0,0">
                      <TextBlock Classes="field-label" Text="季度" />
                      <TextBox Classes="desktop-input"
                               Text="{Binding Season}"
                               PlaceholderText="例如 02 或 S02" />
                    </StackPanel>
                  </TabItem>
                </TabControl>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </Border>

      <Grid Grid.Column="1" RowDefinitions="58,36,*"
            Background="{StaticResource SurfaceBrush}">
        <Border Grid.Row="0" Padding="18,10"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
          <Grid ColumnDefinitions="Auto,*,220,150" ColumnSpacing="10">
            <CheckBox VerticalAlignment="Center"
                      IsChecked="{Binding SelectAll}"
                      Content="全选" />
            <TextBox Grid.Column="2"
                     Classes="desktop-input"
                     Text="{Binding FilterText}"
                     PlaceholderText="搜索文件名" />
            <ComboBox Grid.Column="3"
                      MinHeight="38"
                      ItemsSource="{Binding SortModes}"
                      SelectedIndex="{Binding SortMode}"
                      HorizontalAlignment="Stretch" />
          </Grid>
        </Border>

        <Border Grid.Row="1"
                Padding="16,0"
                Background="#F7F9FA"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
          <Grid ColumnDefinitions="36,1.2*,1.2*,82,78,126" ColumnSpacing="12">
            <TextBlock Grid.Column="1" Classes="muted" Text="原文件名"
                       VerticalAlignment="Center" />
            <TextBlock Grid.Column="2" Classes="muted" Text="重命名预览"
                       VerticalAlignment="Center" />
            <TextBlock Grid.Column="3" Classes="muted" Text="大小"
                       VerticalAlignment="Center" />
            <TextBlock Grid.Column="4" Classes="muted" Text="类型"
                       VerticalAlignment="Center" />
            <TextBlock Grid.Column="5" Classes="muted" Text="修改时间"
                       VerticalAlignment="Center" />
          </Grid>
        </Border>

        <ListBox Grid.Row="2"
                 Classes="file-list"
                 ItemsSource="{Binding FileList}"
                 IsVisible="{Binding FileList.Count}">
          <ListBox.ItemTemplate>
            <DataTemplate DataType="vm:FileItemInfo">
              <Border Padding="16,10"
                      BorderBrush="{StaticResource BorderBrush}"
                      BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="36,1.2*,1.2*,82,78,126" ColumnSpacing="12">
                  <CheckBox VerticalAlignment="Center"
                            IsChecked="{Binding IsSelected}" />
                  <TextBlock Grid.Column="1" Classes="file-name"
                             Text="{Binding Name}"
                             VerticalAlignment="Center" />
                  <Grid Grid.Column="2">
                    <TextBlock Classes="muted" Text="—"
                               VerticalAlignment="Center"
                               IsVisible="{Binding !HasRenamePreview}" />
                    <TextBlock Classes="preview-name"
                               Text="{Binding PreviewName}"
                               VerticalAlignment="Center"
                               IsVisible="{Binding HasRenamePreview}" />
                  </Grid>
                  <TextBlock Grid.Column="3" Classes="muted"
                             Text="{Binding SizeFormatted}"
                             VerticalAlignment="Center" />
                  <TextBlock Grid.Column="4" Classes="muted"
                             Text="{Binding Extension}"
                             TextTrimming="CharacterEllipsis"
                             VerticalAlignment="Center" />
                  <TextBlock Grid.Column="5" Classes="muted"
                             Text="{Binding ModifiedFormatted}"
                             VerticalAlignment="Center" />
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <Grid Grid.Row="2" IsVisible="{Binding !FileList.Count}">
          <StackPanel HorizontalAlignment="Center"
                      VerticalAlignment="Center">
            <TextBlock FontSize="15" FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Text="选择一个文件夹开始"
                       IsVisible="{Binding !HasSelectedPath}" />
            <TextBlock FontSize="15" FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Text="没有找到文件"
                       IsVisible="{Binding HasSelectedPath}" />
          </StackPanel>
        </Grid>
      </Grid>
    </Grid>

    <Border Grid.Row="2"
            Padding="18,10"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,1,0,0">
      <Grid ColumnDefinitions="*,Auto,180" ColumnSpacing="14">
        <TextBlock Classes="muted"
                   Text="{Binding StatusMessage}"
                   TextTrimming="CharacterEllipsis"
                   VerticalAlignment="Center" />
        <StackPanel Grid.Column="1" Orientation="Horizontal"
                    VerticalAlignment="Center" Spacing="4">
          <TextBlock Text="{Binding SelectedCount}"
                     Foreground="{StaticResource SuccessBrush}"
                     FontWeight="SemiBold" />
          <TextBlock Classes="muted" Text="个文件将被处理" />
        </StackPanel>
        <Button Grid.Column="2"
                Classes="command primary"
                Content="执行重命名"
                Command="{Binding RenameCommand}"
                IsEnabled="{Binding CanRename}"
                HorizontalAlignment="Stretch" />
      </Grid>
    </Border>
  </Grid>
</UserControl>
