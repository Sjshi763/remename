<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:remename.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="remename.Views.MainView"
             x:DataType="vm:MainViewModel">
  <Design.DataContext>
    <vm:MainViewModel />
  </Design.DataContext>

  <UserControl.Styles>
    <Style Selector="TextBlock.title">
      <Setter Property="FontSize" Value="24" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Margin" Value="0,0,0,4" />
    </Style>
    <Style Selector="TextBlock.section-title">
      <Setter Property="FontSize" Value="15" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Margin" Value="0,0,0,10" />
    </Style>
    <Style Selector="TextBlock.field-label">
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Margin" Value="0,0,0,5" />
    </Style>
    <Style Selector="TextBlock.muted">
      <Setter Property="Foreground" Value="#64748B" />
    </Style>
    <Style Selector="TextBox">
      <Setter Property="MinHeight" Value="40" />
    </Style>
    <Style Selector="Button">
      <Setter Property="MinHeight" Value="40" />
      <Setter Property="Padding" Value="14,6" />
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="#2563EB" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Border.section">
      <Setter Property="BorderBrush" Value="#E5E7EB" />
      <Setter Property="BorderThickness" Value="0,1,0,0" />
      <Setter Property="Padding" Value="0,16,0,0" />
      <Setter Property="Margin" Value="0,14,0,0" />
    </Style>
  </UserControl.Styles>

  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <StackPanel Margin="20" Spacing="14" MaxWidth="760" HorizontalAlignment="Stretch">
      <StackPanel Spacing="2">
        <TextBlock Classes="title" Text="批量重命名" />
        <TextBlock Classes="muted" Text="{Binding StatusMessage}" TextWrapping="Wrap" />
      </StackPanel>

      <Border Classes="section">
        <StackPanel Spacing="10">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <StackPanel>
              <TextBlock Classes="section-title" Text="连接方式" />
              <CheckBox IsChecked="{Binding IsSmbMode}" Content="使用 SMB 网络共享" />
            </StackPanel>
            <Border Grid.Column="1"
                    BorderBrush="#16A34A"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="10,5"
                    VerticalAlignment="Top"
                    IsVisible="{Binding IsSmbConnected}">
              <TextBlock Text="已连接" Foreground="#15803D" FontWeight="SemiBold" />
            </Border>
            <Border Grid.Column="1"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="10,5"
                    VerticalAlignment="Top"
                    IsVisible="{Binding !IsSmbConnected}">
              <TextBlock Text="未连接" Foreground="#64748B" />
            </Border>
          </Grid>

          <StackPanel Spacing="8" IsVisible="{Binding IsSmbMode}">
            <StackPanel>
              <TextBlock Classes="field-label" Text="服务器地址" />
              <TextBox Text="{Binding SmbServer}" PlaceholderText="192.168.1.100 或 192.168.1.100/share" />
            </StackPanel>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
              <StackPanel>
                <TextBlock Classes="field-label" Text="用户名" />
                <TextBox Text="{Binding SmbUsername}" PlaceholderText="用户名" />
              </StackPanel>
              <StackPanel Grid.Column="1">
                <TextBlock Classes="field-label" Text="密码" />
                <TextBox Text="{Binding SmbPassword}" PasswordChar="*" PlaceholderText="密码" />
              </StackPanel>
            </Grid>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
              <Button Content="连接" Command="{Binding ConnectSmbCommand}" Classes="primary" />
              <Button Grid.Column="1" Content="断开" Command="{Binding DisconnectSmbCommand}"
                      IsEnabled="{Binding IsSmbConnected}" />
            </Grid>
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Classes="section">
        <StackPanel Spacing="10">
          <TextBlock Classes="section-title" Text="目标路径" />
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
            <TextBox Text="{Binding SelectedPath}" PlaceholderText="选择本地文件夹，或输入 smb://server/share/path" />
            <Button Grid.Column="1"
                    Content="浏览"
                    Command="{Binding SelectFolderCommand}"
                    IsVisible="{Binding !IsSmbMode}" />
          </Grid>
        </StackPanel>
      </Border>

      <Border Classes="section">
        <StackPanel Spacing="10">
          <TextBlock Classes="section-title" Text="文件列表" />
          <ListBox ItemsSource="{Binding FileList}" MinHeight="180" MaxHeight="260" />
        </StackPanel>
      </Border>

      <Border Classes="section">
        <StackPanel Spacing="10">
          <TextBlock Classes="section-title" Text="重命名规则" />
          <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
            <StackPanel>
              <TextBlock Classes="field-label" Text="搜索" />
              <TextBox Text="{Binding SearchText}" PlaceholderText="要替换的内容" />
            </StackPanel>
            <StackPanel Grid.Column="1">
              <TextBlock Classes="field-label" Text="替换为" />
              <TextBox Text="{Binding ReplaceText}" PlaceholderText="新的内容" />
            </StackPanel>
          </Grid>
          <Button Content="重命名" Command="{Binding RenameCommand}" Classes="primary"
                  HorizontalAlignment="Stretch" />
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
