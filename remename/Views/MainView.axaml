<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:remename.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="remename.Views.MainView"
             x:DataType="vm:MainViewModel">
  <Design.DataContext>
    <vm:MainViewModel />
  </Design.DataContext>

  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- SMB Connection Section -->
    <TextBlock Grid.Row="0" Text="连接方式" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10" Margin="0,0,0,10">
      <CheckBox IsChecked="{Binding IsSmbMode}" Content="使用SMB网络共享"/>
      <TextBlock Text="状态:" VerticalAlignment="Center"/>
      <TextBlock Text="{Binding IsSmbConnected, StringFormat='已连接'}" 
                 Foreground="Green" VerticalAlignment="Center"
                 IsVisible="{Binding IsSmbConnected}"/>
      <TextBlock Text="未连接" Foreground="Gray" VerticalAlignment="Center"
                 IsVisible="{Binding !IsSmbConnected}"/>
    </StackPanel>

    <!-- SMB Server Connection -->
    <TextBlock Grid.Row="2" Text="SMB服务器地址:" FontWeight="Bold" Margin="0,0,0,5"
               IsVisible="{Binding IsSmbMode}"/>
    <TextBox Grid.Row="3" Text="{Binding SmbServer}" Watermark="例如: 192.168.1.100 或 192.168.1.100/share" Margin="0,0,0,5"
             IsVisible="{Binding IsSmbMode}"/>

    <TextBlock Grid.Row="4" Text="用户名:" FontWeight="Bold" Margin="0,0,0,5"
               IsVisible="{Binding IsSmbMode}"/>
    <TextBox Grid.Row="5" Text="{Binding SmbUsername}" Watermark="用户名" Margin="0,0,0,5"
             IsVisible="{Binding IsSmbMode}"/>

    <TextBlock Grid.Row="6" Text="密码:" FontWeight="Bold" Margin="0,0,0,5"
               IsVisible="{Binding IsSmbMode}"/>
    <TextBox Grid.Row="7" Text="{Binding SmbPassword}" PasswordChar="*" Watermark="密码" Margin="0,0,0,10"
             IsVisible="{Binding IsSmbMode}"/>

    <StackPanel Grid.Row="8" Orientation="Horizontal" Spacing="5" Margin="0,0,0,10"
                IsVisible="{Binding IsSmbMode}">
      <Button Content="连接" Command="{Binding ConnectSmbCommand}" Width="80"/>
      <Button Content="断开" Command="{Binding DisconnectSmbCommand}" Width="80"
              IsEnabled="{Binding IsSmbConnected}"/>
    </StackPanel>

    <!-- File Path Selection -->
    <TextBlock Grid.Row="9" Text="文件夹路径:" FontWeight="Bold" Margin="0,0,0,5"/>
    <StackPanel Grid.Row="10" Orientation="Horizontal" Spacing="5" Margin="0,0,0,10">
      <TextBox Text="{Binding SelectedPath}" Width="300"/>
      <Button Content="浏览..." Command="{Binding SelectFolderCommand}"
              IsVisible="{Binding !IsSmbMode}"/>
    </StackPanel>

    <!-- File List -->
    <TextBlock Grid.Row="11" Text="文件列表:" FontWeight="Bold" Margin="0,0,0,5"/>
    <ListBox Grid.Row="12" ItemsSource="{Binding FileList}" Height="150" Margin="0,0,0,10"/>

    <!-- Rename Section -->
    <StackPanel Grid.Row="13" Spacing="10">
      <StackPanel Orientation="Horizontal" Spacing="5">
        <TextBlock Text="搜索:" FontWeight="Bold" VerticalAlignment="Center" Width="50"/>
        <TextBox Text="{Binding SearchText}" Watermark="输入要搜索的内容" Width="200"/>
        <TextBlock Text="替换为:" FontWeight="Bold" VerticalAlignment="Center" Width="50"/>
        <TextBox Text="{Binding ReplaceText}" Watermark="输入替换的内容" Width="200"/>
        <Button Content="重命名" Command="{Binding RenameCommand}" Width="80"/>
      </StackPanel>
      <TextBlock Text="{Binding StatusMessage}" Foreground="Blue" TextWrapping="Wrap"/>
    </StackPanel>
  </Grid>
</UserControl>
